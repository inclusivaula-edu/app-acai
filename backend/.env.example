# ============================================
# SERVIDOR
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
JWT_SECRET=sua_string_aleatoria_de_64_chars_aqui

# ============================================
# SUPABASE — Configurações → API no painel do Supabase
# ============================================
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ============================================
# STRIPE
# ============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_SEMIANNUAL=price_...
STRIPE_PRICE_ANNUAL=price_...

# ============================================
# WHATSAPP — Z-API (opcional)
# Crie sua instância em https://z-api.io
# Se não configurar, as notificações são ignoradas silenciosamente
# ============================================
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Secret para validar requisições do webhook Z-API (recomendado)
ZAPI_WEBHOOK_SECRET=gere_uma_string_aleatoria_aqui

# ============================================
# EMAIL — nodemailer (para confirmação e recuperação de senha)
# Gmail: use uma "Senha de app" (https://myaccount.google.com/apppasswords)
# Resend: host=smtp.resend.com port=465 user=resend pass=re_...
# Se não configurar, emails são ignorados (mas funciona sem)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app_aqui
EMAIL_FROM="Açaí Shop" <seu_email@gmail.com>

# ============================================
# URLS
# ============================================
FRONTEND_URL=https://seu-frontend.vercel.app
REACT_APP_API_URL=https://seu-backend.up.railway.app/api
